[Unit]
Description=OpenCode server
Documentation=https://opencode.ai/docs/server/

[Service]
Type=simple
WorkingDirectory=%h
Environment="PATH=%h/.opencode/bin:%h/.local/share/mise/shims:%h/.local/bin:/usr/local/bin:/usr/bin:/bin"
Environment="DOCKER_HOST=unix:///var/run/docker.sock"
EnvironmentFile=%h/.config/opencode/server.env
ExecStart=%h/.opencode/bin/opencode serve --port 4096 --hostname 0.0.0.0
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
